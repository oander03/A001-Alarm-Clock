0162            140   ;---------------------------------;
0162            141   ; Routine to initialize the ISR   ;
0162            142   ; for timer 0                     ;
0162            143   ;---------------------------------;
0162            144   Timer0_Init:
0162 438E08     145            orl CKCON, #0b00001000 ; Input for timer 0 is sysclk/1
0165 E589       146            mov a, TMOD
0167 54F0       147            anl a, #0xf0 ; 11110000 Clear the bits for timer 0
0169 4401       148            orl a, #0x01 ; 00000001 Configure timer 0 as 16-timer
016B F589       149            mov TMOD, a
016D 85398C     150            mov TH0, Timer0Reload+1
0170 85388A     151            mov TL0, Timer0Reload+0
0173            152            ; Enable the timer and interrupts
0173 D2A9       153       setb ET0  ; Enable timer 0 interrupt
0175 D28C       154       setb TR0  ; Start timer 0
0177 22         155            ret
0178            156   
0178            157   ;---------------------------------;
0178            158   ; ISR for timer 0.  Set to execute;
0178            159   ; every 1/4096Hz to generate a    ;
0178            160   ; 2048 Hz wave at pin SOUND_OUT   ;
0178            161   ;---------------------------------;
0178            162   Timer0_ISR:
0178            163            ;clr TF0  ; According to the data sheet this is done for us already.
0178            164            ; Timer 0 doesn't have 16-bit auto-reload, so
0178 C28C       165            clr TR0
017A 85398C     166            mov TH0, Timer0Reload+1
017D 85388A     167            mov TL0, Timer0Reload+0
0180 D28C       168            setb TR0
0182 B292       169            cpl SOUND_OUT ; Connect speaker the pin assigned to 'SOUND_OUT'!
0184 32         170            reti
0185            171   
0185            172   ;---------------------------------;
0185            173   ; Routine to initialize the ISR   ;
0185            174   ; for timer 2                     ;
0185            175   ;---------------------------------;
0185            176   Timer2_Init:
0185 75C800     177            mov T2CON, #0 ; Stop timer/counter.  Autoreload mode.
0188 75CDBF     178            mov TH2, #high(TIMER2_RELOAD)
018B 75CC28     179            mov TL2, #low(TIMER2_RELOAD)
018E            180            ; Set the reload value
018E 43C980     181            orl T2MOD, #0x80 ; Enable timer 2 autoreload
0191 75CBBF     182            mov RCMP2H, #high(TIMER2_RELOAD)
0194 75CA28     183            mov RCMP2L, #low(TIMER2_RELOAD)
0197            184            ; Init One millisecond interrupt counter.  It is a 16-bit variable made with two 8-bit parts
0197 E4         185            clr a
0198 F530       186            mov Count1ms+0, a
019A F531       187            mov Count1ms+1, a
019C            188            ; Enable the timer and interrupts
019C 439B80     189            orl EIE, #0x80 ; Enable timer 2 interrupt ET2=1
019F D2CA       190       setb TR2  ; Enable timer 2
01A1 22         191            ret
01A2            192   
01A2            193   ;---------------------------------;
01A2            194   ; ISR for timer 2                 ;
01A2            195   ;---------------------------------;
01A2            196   Timer2_ISR:
01A2 C2CF       197            clr TF2  ; Timer 2 doesn't clear TF2 automatically. Do it in the ISR.  It is bit addressable.
01A4 B284       198            cpl P0.4 ; To check the interrupt rate with oscilloscope. It must be precisely a 1 ms pulse.
01A6            199            
01A6            200            ; The two registers used in the ISR must be saved in the stack
01A6 C0E0       201            push acc
01A8 C0D0       202            push psw
01AA            203            
01AA            204            ; Increment the 16-bit one mili second counter
01AA 0530       205            inc Count1ms+0    ; Increment the low 8-bits first
01AC E530       206            mov a, Count1ms+0 ; If the low 8-bits overflow, then increment high 8-bits
01AE 7002       207            jnz Inc_Done
01B0 0531       208            inc Count1ms+1
01B2            209   
01B2            210   Inc_Done:
01B2            211            ; Check if half second has passed
01B2 E530       212            mov a, Count1ms+0
01B4 B4E816     213            cjne a, #low(1000), Timer2_ISR_done ; Warning: this instruction changes the carry flag!
01B7 E531       214            mov a, Count1ms+1
01B9 B40311     215            cjne a, #high(1000), Timer2_ISR_done
01BC            216            
01BC            217            ; 1 second have passed.  Set a flag so the main program knows
01BC D200       218            setb second_flag ; Let the main program know half second had passed
01BE            219            ;cpl TR0 ; Enable/disable timer/counter 0. This line creates a beep-silence-beep-silence sound.
01BE            220            ; Reset to zero the milli-seconds counter, it is a 16-bit variable
01BE            221            
01BE E4         222            clr a
01BF F530       223            mov Count1ms+0, a
01C1 F531       224            mov Count1ms+1, a
01C3            225            ; Increment the BCD counter
01C3 E532       226            mov a, seconds_counter
01C5            227            
01C5            228   
01C5            229            
01C5            230            ;jnb UPDOWN, Timer2_ISR_decrement
01C5 2401       231            add a, #0x01
01C7 8002       232            sjmp Timer2_ISR_da
01C9            233            
01C9            234            
01C9            235   Timer2_ISR_decrement:
01C9 2499       236            add a, #0x99 ; Adding the 10-complement of -1 is like subtracting 1.
01CB            237   
01CB            238   Timer2_ISR_da:
01CB            239            ;da a ; Decimal adjust instruction.  Check datasheet for more details!
01CB F532       240            mov seconds_counter, a
01CD            241            
01CD            242   Timer2_ISR_done:
01CD D0D0       243            pop psw
01CF D0E0       244            pop acc
01D1 32         245            reti
01D2            246            
