0000              1   ; ISR_example.asm: a) Increments/decrements a BCD variable every half second using
0000              2   ; an ISR for timer 2; b) Generates a 2kHz square wave at pin P1.7 using
0000              3   ; an ISR for timer 0; and c) in the 'main' loop it displays the variable
0000              4   ; incremented/decremented using the ISR for timer 2 on the LCD.  Also resets it to 
0000              5   ; zero if the 'CLEAR' push button connected to P1.5 is pressed.
                  7   $LIST
0000              9   
0000             10   
0000             11   
0000             12   ; Snooze button
0000             13   ; Volume button 
0000             14   ; am pm at 11:59:59 switch
0000             15   ; edit button
0000             16   ; switch blink animations
0000             17   ; watch 
0000             18   ; timer
0000             19   ; timer doesnt have am-pm
0000             20   ; has less buttons
0000             21   
0000             22   ;  N76E003 pinout:
0000             23   ;                               -------
0000             24   ;       PWM2/IC6/T0/AIN4/P0.5 -|1    20|- P0.4/AIN5/STADC/PWM3/IC3
0000             25   ;               TXD/AIN3/P0.6 -|2    19|- P0.3/PWM5/IC5/AIN6
0000             26   ;               RXD/AIN2/P0.7 -|3    18|- P0.2/ICPCK/OCDCK/RXD_1/[SCL]
0000             27   ;                    RST/P2.0 -|4    17|- P0.1/PWM4/IC4/MISO
0000             28   ;        INT0/OSCIN/AIN1/P3.0 -|5    16|- P0.0/PWM3/IC3/MOSI/T1
0000             29   ;              INT1/AIN0/P1.7 -|6    15|- P1.0/PWM2/IC2/SPCLK
0000             30   ;                         GND -|7    14|- P1.1/PWM1/IC1/AIN7/CLO
0000             31   ;[SDA]/TXD_1/ICPDA/OCDDA/P1.6 -|8    13|- P1.2/PWM0/IC0
0000             32   ;                         VDD -|9    12|- P1.3/SCL/[STADC]
0000             33   ;            PWM5/IC7/SS/P1.5 -|10   11|- P1.4/SDA/FB/PWM1
0000             34   ;                               -------
0000             35   ;
0000             36   
0000             37   CLK           EQU 16600000 ; Microcontroller system frequency in Hz
0000             38   TIMER0_RATE   EQU 1024    ; 2048Hz squarewave (peak amplitude of CEM-1203 speaker)
0000             39   TIMER0_RELOAD EQU ((65536-(CLK/TIMER0_RATE)))
0000             40   TIMER2_RATE   EQU 1000     ; 1000Hz, for a timer tick of 1ms
0000             41   TIMER2_RELOAD EQU ((65536-(CLK/TIMER2_RATE)))
0000             42   
0000             43   TONE_1024 EQU ((65536-(CLK/1024)))
0000             44   TONE_4096 EQU ((65536-(CLK/4096)))
0000             45   
0000             46   DOWN_BUTTON   equ P1.6
0000             47   UP_BUTTON     equ P1.7
0000             48   EDIT_BUTTON        equ P3.0
0000             49   CHANGE_BUTTON equ P0.5
0000             50   ONOFF_BUTTON  equ P1.5
0000             51   SOUND_OUT     equ P1.2
0000             52   
0000             53   ; Reset vector
0000             54   org 0x0000
0000 0201D2      55       ljmp main
0003             56   
0003             57   ; External interrupt 0 vector (not used in this code)
0003             58   org 0x0003
0003 32          59            reti
0004             60   
0004             61   ; Timer/Counter 0 overflow interrupt vector
000B             62   org 0x000B
000B 020178      63            ljmp Timer0_ISR
000E             64   
000E             65   ; External interrupt 1 vector (not used in this code)
0013             66   org 0x0013
0013 32          67            reti
0014             68   
0014             69   ; Timer/Counter 1 overflow interrupt vector (not used in this code)
001B             70   org 0x001B
001B 32          71            reti
001C             72   
001C             73   ; Serial port receive/transmit interrupt vector (not used in this code)
0023             74   org 0x0023 
0023 32          75            reti
0024             76            
0024             77   ; Timer/Counter 2 overflow interrupt vector
002B             78   org 0x002B
002B 0201A2      79            ljmp Timer2_ISR
002E             80   
002E             81   ; In the 8051 we can define direct access variables starting at location 0x30 up to location 0x7F
0030             82   dseg at 0x30
0030             83   Count1ms:     ds 2 ; Used to determine when half second has passed
0032             84   seconds_counter:  ds 1 ; The BCD counter incrememted in the ISR and displayed in the main loop
0033             85   minutes_counter:  ds 1
0034             86   hours_counter:  ds 1
0035             87   seconds_counter_2:  ds 1 
0036             88   minutes_counter_2:  ds 1
0037             89   hours_counter_2:  ds 1
0038             90   Timer0Reload:   ds 2     ; 16-bit reload value (low, high)
003A             91   edit_counter:  ds 1
003B             92   edit_counter_2:  ds 1
003C             93   
003C             94   Top_Change_counter:  ds 1
003D             95   Bottom_Change_counter: ds 1
003E             96   
003E             97   
003E             98   ; In the 8051 we have variables that are 1-bit in size.  We can use the setb, clr, jb, and jnb
003E             99   ; instructions with these variables.  This is how you define a 1-bit variable:
0000            100   bseg
0000            101   second_flag: dbit 1 ; Set to one in the ISR every time 500 ms had passed
0001            102   vol_controls: dbit 1
0002            103   am_pm: dbit 1
0003            104   am_pm_2: dbit 1
0004            105   change_flag: dbit 1
0005            106   onoff_flag: dbit 1
0006            107   watch_flag: dbit 1
0007            108   timer_flag: dbit 1
0008            109   
0008            110   am_pm_clamp: dbit 1
0009            111   
002E            112   cseg
002E            113   ; These 'equ' must match the hardware wiring
002E            114   LCD_RS equ P1.3
002E            115   ;LCD_RW equ PX.X ; Not used in this code, connect the pin to GND
002E            116   LCD_E  equ P1.4
002E            117   LCD_D4 equ P0.0
002E            118   LCD_D5 equ P0.1
002E            119   LCD_D6 equ P0.2
002E            120   LCD_D7 equ P0.3
